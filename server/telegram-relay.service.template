[Unit]
Description=Telegram Screenshot Relay
After=network.target

[Service]
WorkingDirectory=/opt/telegram-relay
EnvironmentFile=/etc/telegram-relay/relay.env
EnvironmentFile=-/etc/telegram-relay/admin.env
ExecStart=/opt/telegram-relay/venv/bin/gunicorn -w 1 -b 127.0.0.1:8000 server:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
