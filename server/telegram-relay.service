[Unit]
Description=Telegram Screenshot Relay
After=network.target

[Service]
WorkingDirectory=/opt/telegram-relay
Environment="BOT_TOKEN=YOUR_BOT_TOKEN"
Environment="CHAT_ID=YOUR_CHAT_ID"
Environment="RELAY_SECRET=YOUR_RELAY_SECRET"
ExecStart=/opt/telegram-relay/venv/bin/gunicorn -w 1 -b 127.0.0.1:8000 server:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
